APP_ENV=production
API_PREFIX=/api
FRONTEND_ORIGIN=https://your-frontend.vercel.app

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_IMPORT_MODEL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_CALENDAR_ID=primary
GOOGLE_MAPS_API_KEY=
AGENT_SECRETS={"sigmaris-orchestrator":"replace-with-a-strong-secret"}
SCHEDULE_AGENT_BASE_URL=http://127.0.0.1:8000
SCHEDULE_AGENT_ID=sigmaris-orchestrator
SCHEDULE_AGENT_SECRET=replace-with-the-same-secret
SIGMARIS_PERSONA_PATH=../docs/persona.md
SIGMARIS_REWRITE_MODEL=
SIGMARIS_GUARD_MODEL=
SIGMARIS_TIMEZONE=Asia/Tokyo
SIGMARIS_USER_JWT=
SIGMARIS_REFRESH_TOKEN=
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
PROACTIVE_ENABLED=true

# Local LLM (Ollama)
LOCAL_LLM_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# X (Twitter)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_ENABLED=false

# Sigmaris launch date (YYYY-MM-DD) for day counter
SIGMARIS_LAUNCH_DATE=

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/frontend/node_modules
/backend/.venv/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# python
__pycache__/
*.py[cod]

# next.js
/.next/
/frontend/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
/frontend/.env*

# Phase C-mini: live-generated eval testset contains real user_fact_items
# content (PII-adjacent), regenerated/edited over time — not a source
# artifact. testset.example.json (the demo/pipeline-check fixture) is
# intentionally NOT excluded here and stays tracked.
/backend/eval/testset.json

# JWT persistence: live Supabase session (access+refresh token), written by
# jwt_manager.py after every successful rotation. Equivalent sensitivity to
# .env — must never be committed.
/backend/.state/

# Phase C-full: raw LongMemEval/LoCoMo dataset downloads (see
# backend/scripts/run_longmemeval.py / run_locomo.py for the download
# commands). Not committed — these are large (LongMemEval oracle ~15MB,
# LoCoMo ~2.8MB) third-party files, not source artifacts, and LoCoMo's
# CC BY-NC 4.0 license makes redistributing a checked-in copy an
# unnecessary complication to avoid entirely rather than reason through.
/backend/eval/bench_data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
